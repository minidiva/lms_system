# PostgreSQL для приложения
DB_USER=lms
DB_PASSWORD=lms
DB_NAME=lms
DB_PORT=5432
DB_HOST=lms_db
DB_SSLMODE=disable

# Приложение
PORT=8082
LOG_LEVEL=debug
LOG_FORMAT=text

# Keycloak
KEYCLOAK_HOST=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=YOUR_CLIENT_ID
KEYCLOAK_CLIENT_SECRET=YOUR_CLIENT_SECRET
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=admin

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY_ID=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_ACCESS_KEY=YOUR_MINIO_SECRET
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=YOUR_BUCKET_NAME
